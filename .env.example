# Заявки из листа ожидания приходят в Telegram.
#
# Как получить значения:
# 1. Напиши @BotFather в Telegram, команда /newbot — получишь токен.
# 2. Создай канал или группу, добавь туда бота администратором.
# 3. Узнай chat_id: напиши что-нибудь в канал и открой
#    https://api.telegram.org/bot<ТОКЕН>/getUpdates — там будет chat.id
#    (у каналов и групп он отрицательный, например -1001234567890).
#
# Без этих переменных форма отвечает ошибкой 503 — это сделано намеренно,
# чтобы незамеченная потеря заявок была невозможна.

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
